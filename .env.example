# Contact form (Resend) — without these the form runs in demo mode
RESEND_API_KEY=
CONTACT_TO=uniagent@unitrans.bg
RESEND_FROM="Unitrans Website <no-reply@unitrans.bg>"

# Canonical site URL (production)
NEXT_PUBLIC_SITE_URL=https://unitrans.bg

# Admin CMS — GitHub OAuth App (production only; local uses `npm run cms`)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
